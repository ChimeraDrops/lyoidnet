rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Users collection - allow read for username lookup, write only to own document
    match /users/{userId} {
      // Anyone can read (needed for username lookup during login)
      allow read: if true;
      
      // Only authenticated users can write to their own document
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Projects collection
    match /projects/{projectId} {
      // Anyone can read (needed for joining projects by code)
      allow read: if true;
      
      // Only authenticated users can create projects
      allow create: if request.auth != null;
      
      // Only creator or team members can update;
      // OR any authenticated user can update if the result keeps them in teamMembers (joining)
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.creatorId ||
        request.auth.email in resource.data.teamMembers ||
        request.auth.email in request.resource.data.teamMembers
      );
      
      // Only creator can delete
      allow delete: if request.auth != null && request.auth.uid == resource.data.creatorId;

      // Votes subcollection
      match /votes/{voteId} {
        // Authenticated users can read votes (needed to finalize voting)
        allow read: if request.auth != null;

        // Authenticated users can write their own vote document
        allow write: if request.auth != null;

        // Project creator can delete any vote (for cleanup on project delete)
        allow delete: if request.auth != null &&
          get(/databases/$(database)/documents/projects/$(projectId)).data.creatorId == request.auth.uid;
      }

      // Templates subcollection (PMBOK documents)
      match /templates/{templateId} {
        // Project creator or team members can read/write/delete templates
        allow read, write: if request.auth != null && (
          get(/databases/$(database)/documents/projects/$(projectId)).data.creatorId == request.auth.uid ||
          request.auth.token.email in get(/databases/$(database)/documents/projects/$(projectId)).data.teamMembers
        );
      }
    }
  }
}
